{
  "name": "parkpilot-e2e-automation",
  "version": "1.0.0",
  "description": "Enterprise E2E Automation Framework for ParkPilot Flutter App using Appium 2.x, Mocha, Chai, ExcelJS, and Winston.",
  "main": "e2e/drivers/driverFactory.js",
  "scripts": {
    "test": "mocha e2e/tests/auth.test.js e2e/tests/formValidation.test.js e2e/tests/e2eScenarios.test.js --timeout 300000 --exit",
    "test:auth": "mocha e2e/tests/auth.test.js --timeout 300000 --exit",
    "test:form": "mocha e2e/tests/formValidation.test.js --timeout 300000 --exit",
    "test:e2e": "mocha e2e/tests/e2eScenarios.test.js --timeout 300000 --exit",
    "test:ai": "mocha e2e/tests/smartAi.test.js --timeout 300000 --exit",
    "test:all": "mocha e2e/tests/**/*.test.js --timeout 300000 --exit",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force -ErrorAction SilentlyContinue reports; New-Item -ItemType Directory -Force reports; New-Item -ItemType Directory -Force reports/failures\""
  },
  "dependencies": {
    "appium-flutter-finder": "^0.2.0",
    "chai": "^4.3.7",
    "exceljs": "^4.4.0",
    "mocha": "^10.2.0",
    "mochawesome": "^7.1.3",
    "webdriverio": "^8.24.0",
    "winston": "^3.11.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=16.0.0"
  }
}
